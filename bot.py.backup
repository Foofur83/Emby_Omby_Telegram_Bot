                    await update.message.reply_text("❌ Aanvraag bij Ombi is mislukt.")
                pending.pop(user.id, None)
                return

        # Handle TV series season selection
        sel = state.get("selected")
        if sel:
            bot: OmbiEmbyBot = context.application.bot_data["bot_instance"]
            title = sel.get("title") or sel.get("name")
            
            if text.lower() == "all":
                # Request all seasons
                emby_check = await bot.emby_search(title, content_type="Series")
                if emby_check and isinstance(emby_check, dict) and (emby_check.get("TotalRecordCount") or emby_check.get("Items")):
                    await update.message.reply_text(f"✅ '{title}' staat al in Emby.")
                    records = load_requests()
                    records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": title, "content_type": "Series", "ombi_response": None, "requested_at": datetime.utcnow().isoformat(), "notified": True})
                    save_requests(records)
                    pending.pop(user.id, None)
                    return
                
                await update.message.reply_text(f"Aanvragen van hele serie '{title}' bij Ombi...")
                resp = await bot.ombi_request(sel, media_type="tv")
                if resp:
                    records = load_requests()
                    records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": title, "content_type": "Series", "ombi_response": resp, "requested_at": datetime.utcnow().isoformat(), "notified": False})
                    save_requests(records)
                    await update.message.reply_text("✅ Serie aangevraagd! Ik laat je weten als het in Emby staat.")
                else:
                    await update.message.reply_text("❌ Serie aanvragen bij Ombi mislukt.")
                pending.pop(user.id, None)
                return

            if text.isdigit():
                season_num = int(text)
                emby_check = await bot.emby_search(title, content_type="Series")
                if emby_check and isinstance(emby_check, dict) and (emby_check.get("TotalRecordCount") or emby_check.get("Items")):
                    await update.message.reply_text(f"✅ '{title}' (seizoen {season_num}) staat al in Emby.")
                    records = load_requests()
                    records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": f"{title} - S{season_num}", "content_type": "Series", "ombi_response": None, "requested_at": datetime.utcnow().isoformat(), "notified": True})
                    save_requests(records)
                    pending.pop(user.id, None)
                    return
                
                await update.message.reply_text(f"Aanvragen van seizoen {season_num} van '{title}' bij Ombi...")
                payload = sel.copy()
                payload["requestedSeasons"] = [season_num]
                resp = await bot.ombi_request(payload, media_type="tv")
                if resp:
                    records = load_requests()
                    records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": f"{title} - S{season_num}", "content_type": "Series", "ombi_response": resp, "requested_at": datetime.utcnow().isoformat(), "notified": False})
                    save_requests(records)
                    await update.message.reply_text("✅ Seizoen aangevraagd! Ik laat je weten als het in Emby staat.")
                else:
                    await update.message.reply_text("❌ Seizoen aanvragen bij Ombi mislukt.")
                pending.pop(user.id, None)
                return

    # Try to extract a title from the message
    title = extract_title_from_message(text)
    
    if title:
        # User wants to request something!
        bot: OmbiEmbyBot = context.application.bot_data["bot_instance"]
        
        await update.message.reply_text(f"🔍 Zoeken naar '{title}'...")
        results = await bot.ombi_search(title)
        
        if not results:
            await update.message.reply_text("Sorry, ik kon dat niet vinden. Probeer het anders te formuleren.")
            return
        
        # Show multiple results for user to choose
        if len(results) > 1:
            pending = context.application.bot_data.setdefault("pending", {})
            pending[user.id] = {"query": title, "choices": results[:6]}
            text_lines = ["Ik vond deze resultaten — reageer met het nummer:"]
            for i, item in enumerate(results[:6], 1):
                name = item.get("title") or item.get("name")
                typ = item.get("mediaType", "Unknown")
                year = (item.get("releaseDate") or item.get("firstAired") or "")[:4]
                text_lines.append(f"{i}. {name} ({typ} {year})")
            await update.message.reply_text("\n".join(text_lines))
            return
        
        # Only one result - request directly
        item = results[0]
        item_title = item.get('title') or item.get('name')
        media_type = item.get("mediaType", "").lower()
        
        # Check if TV show
        if media_type in ("tv", "series"):
            await update.message.reply_text(
                f"Gevonden: {item_title}\n\nReageer met:\n"
                "• 'all' voor alle seizoenen\n"
                "• Een seizoen nummer (bijv. '1' of '2') voor een specifiek seizoen"
            )
            pending = context.application.bot_data.setdefault("pending", {})
            pending[user.id] = {"selected": item}
            return
        
        # Movie - request directly
        await update.message.reply_text(f"Aanvragen van '{item_title}'...")
        resp = await bot.ombi_request(item, media_type="movie")
        if resp:
            records = load_requests()
            records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": item.get('title') or item.get('name') or title, "content_type": "Movie", "ombi_response": resp, "requested_at": datetime.utcnow().isoformat(), "notified": False})
            save_requests(records)
            await update.message.reply_text("✅ Aanvraag opgeslagen! Ik laat je weten als het in Emby staat.")
        else:
            await update.message.reply_text("❌ Aanvragen mislukt. Check de bot logs.")
        return
    
    # Casual replies (Nederlands)
    low = text.lower()
    if any(g in low for g in ("hi", "hallo", "hey", "hoi", "dag", "goedemorgen", "goedemiddag", "goedenavond")):
        await update.message.reply_text(f"Hey {update.effective_user.first_name}! Zeg me wat je wilt kijken en ik zoek het voor je.")
        return
    if "dank" in low or "bedankt" in low or "thanks" in low:
        await update.message.reply_text("Graag gedaan! Veel kijkplezier! 🎬")
        return
    if "help" in low or "wat kun je" in low or "hoe werkt" in low:
        await update.message.reply_text("Vertel me gewoon wat je wilt kijken! Bijvoorbeeld:\n• \"Ik wil Inception kijken\"\n• \"Voeg Breaking Bad toe\"\n• \"Zoek The Matrix\"")
        return
    
    # Probeer AI conversatie voor natuurlijke chat
    ai: DutchConversationalAI = context.application.bot_data.get("ai_chat")
    if ai and ai.enabled:
        try:
            response = await ai.generate_response(text)
            if response:
                await update.message.reply_text(response)
                return
        except Exception as e:
            logger.debug("AI chat mislukt: %s", e)
    
    # Standaard onduidelijk bericht
    await update.message.reply_text("Niet zeker wat je bedoelt. Probeer iets zoals \"Ik wil Inception kijken\" of gebruik /help voor voorbeelden.")


async def background_poller(application):
    bot: OmbiEmbyBot = application.bot_data["bot_instance"]
    while True:
        try:
            records = load_requests()
            changed = False
            for r in records:
                if r.get("notified"):
                    continue
                title = r.get("title")
                ctype = r.get("content_type") or "Movie"
                emby_res = await bot.emby_search(title, content_type=ctype)
                if emby_res and isinstance(emby_res, dict):
                    items = emby_res.get("Items") or []
                    if items:
                        r["notified"] = True
                        changed = True
                        uid = r.get("telegram_user_id")
                        try:
                            await application.bot.send_message(chat_id=uid, text=f"Good news — '{title}' is now available in Emby!")
                        except Exception:
                            logger.exception("Failed to send notification to %s", uid)
            if changed:
                save_requests(records)
        except Exception:
            logger.exception("Error in poller")
        await asyncio.sleep(bot.poll_interval)


def load_config(path: str = "config.yaml") -> dict:
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            return yaml.safe_load(f) or {}
    return {}


def main():
    config = load_config()
    token = config.get("telegram_token") or os.environ.get("TELEGRAM_TOKEN")
    if not token:
        print("Telegram token missing. Set telegram_token in config.yaml or TELEGRAM_TOKEN env var.")
        return

    bot_instance = OmbiEmbyBot(config)

    app = ApplicationBuilder().token(token).build()
    app.bot_data["bot_instance"] = bot_instance
    
    # Initialiseer Nederlandse conversatie AI
    ai_chat = DutchConversationalAI()
    app.bot_data["ai_chat"] = ai_chat
    if ai_chat.enabled:
        print("🤖 Nederlandse conversatie AI ingeschakeld (GroNLP GPT-2)")
        print("   Model wordt gedownload (~500MB) bij eerste gebruik")
    else:
        print("ℹ️  Conversatie AI uitgeschakeld (installeer transformers & torch om in te schakelen)")

    app.add_handler(CommandHandler("start", start_command))
    app.add_handler(CommandHandler("help", help_command))
    app.add_handler(CommandHandler("request", request_command))
    app.add_handler(CommandHandler("status", status_command))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, text_handler))

    async def on_startup(application):
        await bot_instance.ensure_session()
        application.create_task(background_poller(application))

    app.post_init = on_startup

    print("Starting bot — press Ctrl-C to stop")
    app.run_polling()


if __name__ == "__main__":
    main()
