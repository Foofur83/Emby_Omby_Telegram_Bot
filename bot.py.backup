                    await update.message.reply_text(f"✅ '{title}' staat al in Emby.")
                    records = load_requests()
                    records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": title, "content_type": "Movie", "ombi_response": None, "requested_at": datetime.utcnow().isoformat(), "notified": True})
                    save_requests(records)
                    pending.pop(user.id, None)
                    return
                
                # Request via Ombi
                await update.message.reply_text(f"Aanvragen van '{title}' bij Ombi...")
                resp = await bot.ombi_request(choice, media_type="movie")
                if resp:
