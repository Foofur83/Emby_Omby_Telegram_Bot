                    records.append({"telegram_user_id": user.id, "telegram_username": user.username, "title": title, "content_type": "Movie", "ombi_response": resp, "requested_at": datetime.utcnow().isoformat(), "notified": False})
                    save_requests(records)
                    await update.message.reply_text("✅ Aanvraag opgeslagen! Ik laat je weten als het in Emby staat.")
