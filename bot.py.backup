async def status_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    records = load_requests()
    yours = [r for r in records if r.get("telegram_user_id") == user.id]
    if not yours:
        await update.message.reply_text("You have no saved requests.")
        return
    texts = [f"- {r.get('title')} ({'Notified' if r.get('notified') else 'Pending'})" for r in yours]
    await update.message.reply_text("\n".join(texts))


def extract_title_from_message(text: str) -> str | None:
    """Extract movie/TV title from natural language request (Nederlands + Engels)"""
    text_lower = text.lower().strip()
    
    # Request keywords (Nederlands + Engels)
    request_keywords = [
        # Nederlands
        "kijken", "zoeken", "toevoegen", "voeg toe", "vind", "zoek", "wil", "wilt", 
        "graag", "download", "heb nodig", "kan je", "kun je", "wil graag", "zou graag",
        "laat zien", "geef me", "zoek naar", "ik wil", "we willen",
        # Engels
        "watch", "add", "request", "get", "find", "search", "want", "need",
        "looking for", "can you", "could you", "would you", "i'd like", "show me"
    ]
    
    # Check if this looks like a request
    has_keyword = any(kw in text_lower for kw in request_keywords)
    
    if not has_keyword:
        return None
    
    # Remove common request phrases (Nederlands + Engels)
    patterns_to_remove = [
        # Nederlands
        r"^(kan je|kun je|kunt je|zou je|wil je|kun jij|kan jij)\s+",
        r"^(ik wil|ik zou|ik wilt|we willen|wij willen|graag)\s+",
        r"^(laat|geef|toon|laat zien|geef me|toon me)\s+",
        r"\b(kijken|zoeken|toevoegen|vinden|downloaden|hebben|zien)\s+",
        r"\b(voeg toe|zoek naar|zoek|vind|pak|haal op)\s+",
        r"^(de film|de serie|de show|film|serie|show|een film|een serie)\s+",
        # Engels
        r"^(can you|could you|would you|please|i want to|i'd like to|i want|i need|looking for)\s+",
        r"\b(watch|add|request|get|find|search|search for|show me)\s+",
        r"^(the movie|the show|the series|movie|show|series)\s+",
    ]
    
    import re
    cleaned = text
    for pattern in patterns_to_remove:
        cleaned = re.sub(pattern, "", cleaned, flags=re.IGNORECASE)
    
    cleaned = cleaned.strip().strip('"').strip("'").strip()
    
    # If we have something left, return it
    if len(cleaned) > 1:
        return cleaned
    
    return None


async def show_suggestion(update: Update, context: ContextTypes.DEFAULT_TYPE, result: dict, index: int, total: int, state: dict):
    """Toon 1 suggestie met poster en ja/nee knoppen"""
    name = result.get("title") or result.get("name", "Onbekend")
    media_type = result.get("mediaType", "Unknown")
    year = (result.get("releaseDate") or result.get("firstAired") or "")[:4]
    overview = result.get("overview", "Geen beschrijving beschikbaar")[:200]
    
    caption = f"📽️ **{name}** ({media_type} {year})\n\n{overview}\n\n({index + 1}/{total})"
    
    # Probeer poster te vinden
    poster_url = None
    if result.get("posterPath"):
        # TMDB poster
        poster_url = f"https://image.tmdb.org/t/p/w500{result['posterPath']}"
    
    # Inline keyboard met ja/nee
    keyboard = [
        [
            InlineKeyboardButton("✅ Ja, deze!", callback_data=f"accept_{index}"),
            InlineKeyboardButton("❌ Nee, volgende", callback_data=f"next_{index}")
        ]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    try:
        if poster_url:
            await update.message.reply_photo(
                photo=poster_url,
                caption=caption,
                reply_markup=reply_markup,
                parse_mode="Markdown"
            )
        else:
            await update.message.reply_text(
                caption,
                reply_markup=reply_markup,
                parse_mode="Markdown"
            )
    except Exception as e:
        logger.warning(f"Failed to send photo: {e}")
        await update.message.reply_text(
            caption,
            reply_markup=reply_markup,
            parse_mode="Markdown"
        )


async def callback_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle inline keyboard button presses"""
    query = update.callback_query
    await query.answer()
    
    user = query.from_user
    data = query.data
    
    pending = context.application.bot_data.setdefault("pending", {})
    state = pending.get(user.id)
    
    if not state or "results" not in state:
        await query.edit_message_caption(caption="⚠️ Sessie verlopen. Probeer opnieuw te zoeken.")
        return
    
    results = state["results"]
    current_index = state.get("current_index", 0)
    
    if data.startswith("accept_"):
        # Gebruiker accepteert deze suggestie
        result = results[current_index]
        await query.edit_message_caption(caption=f"✅ Geselecteerd: {result.get('title') or result.get('name')}")
        
        # Check of het een serie is
        media_type = result.get("mediaType", "").lower()
        if media_type in ("tv", "series"):
            # Vraag om seizoen keuze
            state["selected"] = result
            await query.message.reply_text(
                f"Is dit voor alle seizoenen of een specifiek seizoen?\n\n"
                "Reageer met:\n"
                "• 'all' voor alle seizoenen\n"
                "• Een nummer (bijv. '1' voor seizoen 1)"
            )
        else:
            # Film - direct aanvragen
            bot: OmbiEmbyBot = context.application.bot_data["bot_instance"]
            await query.message.reply_text(f"Aanvragen van '{result.get('title')}'...")
            resp = await bot.ombi_request(result, media_type="movie")
            if resp:
                records = load_requests()
                records.append({
                    "telegram_user_id": user.id,
                    "telegram_username": user.username,
                    "title": result.get('title') or result.get('name'),
                    "content_type": "Movie",
                    "ombi_response": resp,
                    "requested_at": datetime.utcnow().isoformat(),
                    "notified": False
                })
                save_requests(records)
                await query.message.reply_text("✅ Aanvraag opgeslagen! Ik laat je weten als het in Emby staat.")
            else:
                await query.message.reply_text("❌ Aanvragen mislukt. Check de bot logs.")
            pending.pop(user.id, None)
    
    elif data.startswith("next_"):
        # Volgende suggestie
        next_index = current_index + 1
        if next_index >= len(results):
            await query.edit_message_caption(caption="❌ Geen resultaten meer. Probeer een andere zoekopdracht.")
            pending.pop(user.id, None)
            return
        
        state["current_index"] = next_index
        await query.delete_message()
        # Stuur nieuwe suggestie als regulier bericht
        await show_suggestion(query, context, results[next_index], next_index, len(results), state)


async def text_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.strip()
    user = update.effective_user

    pending = context.application.bot_data.setdefault("pending", {})
    state = pending.get(user.id)
    
    # Check if we're waiting for media type
    if state and state.get("awaiting_type"):
        text_lower = text.lower()
        title = state.get("title")
        
        # Detect film or serie
        media_type = None
        if any(word in text_lower for word in ["film", "movie"]):
            media_type = "movie"
        elif any(word in text_lower for word in ["serie", "series", "show", "tv"]):
            media_type = "tv"
        else:
            await update.message.reply_text("Ik begrijp niet of je een film of serie bedoelt. Reageer met 'film' of 'serie'.")
            return
        
        # Search in Ombi
        bot: OmbiEmbyBot = context.application.bot_data["bot_instance"]
        await update.message.reply_text(f"🔍 Zoeken naar {title}...")
        results = await bot.ombi_search(title)
        
        if not results:
            await update.message.reply_text("Sorry, ik kon dat niet vinden. Probeer het anders te formuleren.")
            pending.pop(user.id, None)
            return
        
        # Filter results by media type
        filtered = [r for r in results if r.get("mediaType", "").lower() in (media_type, "tv" if media_type == "tv" else "movie")]
        if not filtered:
            filtered = results  # Fallback to all results
        
        # Save results and show first one
        state["results"] = filtered
        state["current_index"] = 0
        state.pop("awaiting_type", None)
        
        await show_suggestion(update, context, filtered[0], 0, len(filtered), state)
        return
    
    if state:
        # Handle season selection for TV shows
        if state.get("selected"):
            sel = state["selected"]
            title = sel.get("title") or sel.get("name")
            bot: OmbiEmbyBot = context.application.bot_data["bot_instance"]
            if 0 <= idx < len(choices):
                choice = choices[idx]
                bot: OmbiEmbyBot = context.application.bot_data["bot_instance"]
                media_type = choice.get("mediaType", "").lower()
                title = choice.get("title") or choice.get("name")
                
                # Check if TV show
                if media_type in ("tv", "series"):
                    await update.message.reply_text(
                        f"Geselecteerd: {title}\n\nReageer met:\n"
                        "• 'all' voor alle seizoenen\n"
                        "• Een seizoen nummer (bijv. '1' of '2') voor een specifiek seizoen"
                    )
                    pending[user.id] = {"selected": choice}
                    return
                
                # Movie - check Emby first
                emby_check = await bot.emby_search(title, content_type="Movie")
