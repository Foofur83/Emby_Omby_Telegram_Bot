# Example configuration for the Telegram + Ombi + Emby bot
# Copy this to `config.yaml` and fill in your actual values.

# Telegram Bot Token (get from @BotFather on Telegram)
telegram_token: "YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Admin Telegram user ID (get from @userinfobot on Telegram)
# This user has rights to approve new users with /approve
admin_telegram_id: 123456789

# Ombi settings
ombi_url: "https://ombi.yourdomain.com"  # Your Ombi server URL
ombi_api_key: "YOUR_OMBI_API_KEY_HERE"   # Get from Ombi Settings → Ombi → API Key
ombi_api_key_header: "ApiKey"  # Usually "ApiKey" or "Authorization"

# Emby settings
emby_url: "https://emby.yourdomain.com"  # Your Emby server URL
emby_api_key: "YOUR_EMBY_API_KEY_HERE"   # Get from Emby Dashboard → Advanced → API Keys

# Poll interval in seconds for checking if requested items appear in Emby
# How often the bot checks for new content and sends notifications
poll_interval_seconds: 60
